{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@trustrespond/db": ["packages/db/src/index.ts"],
      "@trustrespond/ai": ["packages/ai/src/index.ts"],
      "@trustrespond/parsers": ["packages/parsers/src/index.ts"],
      "@trustrespond/ui": ["packages/ui/src/index.tsx"],
      "@trustrespond/config": ["packages/config/src/index.ts"]
    }
  }
}
